{
  "name": "overworld",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "cleanup": "rm -rf *.ipa *.apk *.aab",
    "build:android:dev": "eas build -p android --local --profile development --clear-cache",
    "build:android:preview": "eas build -p android --local --profile preview --clear-cache",
    "build:android:staging": "eas build -p android --local --profile staging --clear-cache",
    "build:android:production": "eas build -p android --local --profile production --clear-cache",
    "version:bump": "node -e \"const fs=require('fs');const p=JSON.parse(fs.readFileSync('package.json','utf8'));const [maj,min,patch]=p.version.split('.');p.version=maj+'.'+min+'.'+(+patch+1);fs.writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n');console.log('Version bumped to '+p.version)\"",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/native": "^7.2.2",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-audio": "^1.1.1",
    "expo-background-task": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "^8.0.10",
    "expo-document-picker": "^14.0.8",
    "expo-file-system": "^55.0.17",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-notifications": "^55.0.22",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-sharing": "^55.0.18",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-ble-plx": "^3.5.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.2",
    "react-native-wifi-reborn": "^4.13.6",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "^2.4.14",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.17",
    "husky": "^9.1.7",
    "jest-expo": "^55.0.16",
    "lint-staged": "^16.4.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.3"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": ["@testing-library/jest-native/extend-expect"],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-ble-plx|react-native-wifi-reborn)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["biome check --write"]
  }
}
